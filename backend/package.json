{
  "name": "gpu-benchmark-backend",
  "version": "1.0.0",
  "description": "Backend API pour GPU LLM Benchmark data management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "bootstrap": "node src/db/bootstrap.js",
    "bootstrap:reset": "node src/db/bootstrap.js --reset",
    "dev:seed-fake-prices": "node src/db/seedFakePriceHistory.js --reset",
    "seed": "node src/db/seeds.js",
    "seed:reset": "node src/db/seeds.js --reset",
    "migrate": "node src/db/migrations.js",
    "migrate:reset": "node src/db/migrations.js --reset",
    "test": "node --test --test-concurrency=1 test/auth.api.test.js test/models.api.test.js test/gpu.api.test.js test/backup.api.test.js test/analyticalProfile.utils.test.js",
    "test:backup": "node --test --test-concurrency=1 test/backup.api.test.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
