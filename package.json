{
  "name": "gpu-benchmark-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:served": "concurrently -k -n FRONT,BACK \"npm run build:watch\" \"npm --prefix backend run dev\"",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "bootstrap:data": "npm --prefix backend run bootstrap",
    "test": "vitest run"
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "jsdom": "^24.1.3",
    "vite": "^5.4.8",
    "vitest": "^4.1.4"
  }
}
